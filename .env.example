# Velix Open-Source Environment Variables Example
# Duplicate this file to .env and configure the parameters as needed

# ─── CAPTCHA Solver Integration ───────────────────────────────────────────────
# API Key / token for the third-party automated captcha solving service
VITE_CAPTCHA_API_KEY=

# ─── Telegram Alerting Integrations ───────────────────────────────────────────
# Active bot token credential generated via Telegram BotFather
VITE_TELEGRAM_BOT_TOKEN=
# Target group or channel ID where notifications should be routed
VITE_TELEGRAM_CHAT_ID=
